    <header class="top-header">
    <button onclick="location.href='/admin/categories'" class="back-btn">
        <i class="fa-solid fa-arrow-left"></i> 
    </button>
    <h2>Subcategories of <%= category.name %></h2>
    <div></div>
</header>

<div class="container">

    <div class="actions">
        <button id="add-subcategory-btn"
                data-id="<%= category._id %>"
                class="primary-btn">
            <i class="fa-solid fa-plus"></i> Add Subcategory
        </button>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Subcategory</th>
                    <th>Edit</th>
                </tr>
            </thead>
            <tbody>
                <% category.subcategories.forEach(sub=>{ %>
                    <tr>
                        <td class="subcat-name"><%= sub.name %></td>
                        <td>
                            <button class="edit-subcategory"
                                    data-subid="<%= sub._id %>"
                                    data-name="<%= sub.name %>"
                                    data-categoryid="<%= category._id %>">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </button>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
    <script src="/jsExpress/adminSubcategories.js"></script>
</body>
